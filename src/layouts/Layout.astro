---
import '../styles/global.css'
interface Props {
  title?: string;
  description?: string;
  schema?: string;
}
const {
  title = 'Fitness-Complete — Starter Kits for Every Sport',
  description = 'Curated starter kits for gym, Pilates, running, home gym, and boxing. Researched from real beginners, not influencers.',
  schema,
} = Astro.props;
const canonicalURL = `https://www.fitness-complete.com${Astro.url.pathname}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {schema && <Fragment set:html={`<script type="application/ld+json">${schema}</script>`} />}
    <title>{title}</title>
  </head>
  <body class="text-gray-900 antialiased">
    <slot />

    <!-- Shared footer -->
    <footer class="bg-[#0f172a] text-white mt-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-10">

          <!-- Column 1: Navigation -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Starter Kits</p>
            <ul class="space-y-2">
              <li><a href="/gym-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Gym</a></li>
              <li><a href="/pilates-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Pilates</a></li>
              <li><a href="/running-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Running</a></li>
              <li><a href="/home-gym-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Home Gym</a></li>
              <li><a href="/boxing-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Boxing</a></li>
              <li><a href="/gifts" class="text-sm text-slate-300 hover:text-white transition-colors">Gift Ideas</a></li>
            </ul>
          </div>

          <!-- Column 2: Research Sources -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Research Sources</p>
            <ul class="space-y-2">
              <li><span class="text-sm text-slate-400">r/fitness</span></li>
              <li><span class="text-sm text-slate-400">r/beginnerfitness</span></li>
              <li><span class="text-sm text-slate-400">r/xxfitness</span></li>
              <li><span class="text-sm text-slate-400">Wirecutter</span></li>
              <li><span class="text-sm text-slate-400">Garage Gym Reviews</span></li>
              <li><span class="text-sm text-slate-400">CNN Underscored</span></li>
            </ul>
          </div>

          <!-- Column 3: Legal -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Legal</p>
            <ul class="space-y-2">
              <li><a href="/about" class="text-sm text-slate-300 hover:text-white transition-colors">About</a></li>
              <li><a href="/privacy-policy" class="text-sm text-slate-300 hover:text-white transition-colors">Privacy Policy</a></li>
            </ul>
          </div>

        </div>

        <!-- Bottom bar -->
        <div class="border-t border-slate-700 pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <p class="text-sm font-bold text-white">fitness-complete.com</p>
          <p class="text-xs text-slate-500">This site contains affiliate links. We may earn a commission at no extra cost to you.</p>
          <p class="text-xs text-slate-500">Last updated: March 2026</p>
        </div>
      </div>
    </footer>

    <!-- Cookie banner -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 bg-gray-900 text-white z-50" style="display:none">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-start sm:items-center gap-3 justify-between">
        <p class="text-sm text-gray-300">
          This site uses cookies for analytics. By continuing you accept our
          <a href="/privacy-policy" class="underline hover:text-white transition-colors">Privacy Policy</a>.
        </p>
        <button
          id="cookie-accept"
          class="flex-shrink-0 bg-white text-gray-900 text-sm font-semibold px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors"
        >
          Accept
        </button>
      </div>
    </div>

    <script>
      (function () {
        if (!localStorage.getItem('cookieAccepted')) {
          document.getElementById('cookie-banner').style.display = 'block';
        }
        document.getElementById('cookie-accept').addEventListener('click', function () {
          localStorage.setItem('cookieAccepted', 'true');
          document.getElementById('cookie-banner').style.display = 'none';
        });
      })();
    </script>

    <script>
      // Sticky TOC scroll tracking for sport pages
      const sections = document.querySelectorAll('[data-product-section]');
      const tocLinks = document.querySelectorAll('.toc-link');
      if (sections.length > 0 && tocLinks.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                tocLinks.forEach((link) => {
                  link.classList.remove('border-gray-900', 'text-gray-900', 'font-semibold');
                  link.classList.add('border-transparent', 'text-slate-400');
                });
                const activeLink = document.querySelector(`.toc-link[data-section="${entry.target.id}"]`);
                if (activeLink) {
                  activeLink.classList.remove('border-transparent', 'text-slate-400');
                  activeLink.classList.add('border-gray-900', 'text-gray-900', 'font-semibold');
                }
              }
            });
          },
          { rootMargin: '-10% 0px -70% 0px' }
        );
        sections.forEach((section) => observer.observe(section));
      }
    </script>
  </body>
</html>
