---
import '../styles/global.css'
import Analytics from '@vercel/analytics/astro'
interface Props {
  title?: string;
  description?: string;
  schema?: string;
}
const {
  title = 'Fitness-Complete — Starter Kits for Every Sport',
  description = 'Curated starter kits for gym, Pilates, running, home gym, and boxing. Researched from real beginners, not influencers.',
  schema,
} = Astro.props;
const canonicalURL = `https://www.fitness-complete.com${Astro.url.pathname}`;
const path = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {schema && <Fragment set:html={`<script type="application/ld+json">${schema}</script>`} />}
    <title>{title}</title>
  </head>
  <body class="text-gray-900 antialiased">
    <header class="border-b border-gray-100 bg-[#fafaf8]">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-[#0f172a] hover:opacity-75 transition-opacity" style="font-size: 20px; letter-spacing: -0.5px; line-height: 1; text-decoration: none;">
          <span style="font-weight: 700;">fitness</span><span style="font-weight: 300;">complete</span>
        </a>
        <nav class="hidden sm:flex gap-6 text-sm text-gray-500">
          <a href="/gym-starter-set" class={`transition-colors ${path === '/gym-starter-set' ? 'text-gray-900 font-semibold' : 'hover:text-gray-900'}`}>Gym</a>
          <a href="/pilates-starter-set" class={`transition-colors ${path === '/pilates-starter-set' ? 'text-gray-900 font-semibold' : 'hover:text-gray-900'}`}>Pilates</a>
          <a href="/running-starter-set" class={`transition-colors ${path === '/running-starter-set' ? 'text-gray-900 font-semibold' : 'hover:text-gray-900'}`}>Running</a>
          <a href="/home-gym-starter-set" class={`transition-colors ${path === '/home-gym-starter-set' ? 'text-gray-900 font-semibold' : 'hover:text-gray-900'}`}>Home Gym</a>
          <a href="/pickleball-starter-set" class={`transition-colors ${path === '/pickleball-starter-set' ? 'text-gray-900 font-semibold' : 'hover:text-gray-900'}`}>Pickleball</a>
          <a href="/gifts" class={`transition-colors font-medium ${path === '/gifts' ? 'text-gray-900 font-semibold' : 'text-gray-700 hover:text-gray-900'}`}>🎁 Gifts</a>
        </nav>
        <!-- Hamburger button (mobile only) -->
        <button id="menu-toggle" class="sm:hidden flex flex-col justify-center gap-[5px] p-2 -mr-2" aria-label="Toggle menu" aria-expanded="false">
          <span class="block w-6 h-0.5 bg-gray-900 transition-all duration-200" id="bar1"></span>
          <span class="block w-6 h-0.5 bg-gray-900 transition-all duration-200" id="bar2"></span>
          <span class="block w-6 h-0.5 bg-gray-900 transition-all duration-200" id="bar3"></span>
        </button>
      </div>
      <!-- Mobile dropdown menu -->
      <div id="mobile-menu" class="sm:hidden hidden bg-[#fafaf8] border-t border-gray-100">
        <nav class="max-w-[1400px] mx-auto px-4 py-3 flex flex-col">
          <a href="/gym-starter-set" class={`py-3 text-sm border-b border-gray-100 transition-colors ${path === '/gym-starter-set' ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900'}`}>Gym</a>
          <a href="/pilates-starter-set" class={`py-3 text-sm border-b border-gray-100 transition-colors ${path === '/pilates-starter-set' ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900'}`}>Pilates</a>
          <a href="/running-starter-set" class={`py-3 text-sm border-b border-gray-100 transition-colors ${path === '/running-starter-set' ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900'}`}>Running</a>
          <a href="/home-gym-starter-set" class={`py-3 text-sm border-b border-gray-100 transition-colors ${path === '/home-gym-starter-set' ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900'}`}>Home Gym</a>
          <a href="/pickleball-starter-set" class={`py-3 text-sm border-b border-gray-100 transition-colors ${path === '/pickleball-starter-set' ? 'text-gray-900 font-semibold' : 'text-gray-600 hover:text-gray-900'}`}>Pickleball</a>
          <a href="/gifts" class={`py-3 text-sm transition-colors font-medium ${path === '/gifts' ? 'text-gray-900 font-semibold' : 'text-gray-700 hover:text-gray-900'}`}>🎁 Gifts</a>
        </nav>
      </div>
    </header>

    <slot />

    <!-- Shared footer -->
    <footer class="bg-[#0f172a] text-white mt-16">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-10">

          <!-- Column 1: Navigation -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Starter Kits</p>
            <ul class="space-y-2">
              <li><a href="/gym-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Gym</a></li>
              <li><a href="/pilates-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Pilates</a></li>
              <li><a href="/running-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Running</a></li>
              <li><a href="/home-gym-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Home Gym</a></li>
              <li><a href="/pickleball-starter-set" class="text-sm text-slate-300 hover:text-white transition-colors">Pickleball</a></li>
              <li><a href="/gifts" class="text-sm text-slate-300 hover:text-white transition-colors">Gift Ideas</a></li>
            </ul>
          </div>

          <!-- Column 2: Research Sources -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Research Sources</p>
            <ul class="space-y-2">
              <li><a href="https://www.reddit.com/r/fitness/" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors">r/fitness</a></li>
              <li><a href="https://www.reddit.com/r/beginnerfitness/" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors">r/beginnerfitness</a></li>
              <li><a href="https://www.reddit.com/r/xxfitness/" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors">r/xxfitness</a></li>
              <li><a href="https://www.nytimes.com/wirecutter/" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors">Wirecutter</a></li>
              <li><a href="https://www.garagegymreviews.com/" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors">Garage Gym Reviews</a></li>
              <li><a href="https://www.cnn.com/cnn-underscored/reviews/fitness" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-300 hover:text-white transition-colors">CNN Underscored</a></li>
            </ul>
          </div>

          <!-- Column 3: About -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">About</p>
            <ul class="space-y-2">
              <li><a href="/blog" class="text-sm text-slate-300 hover:text-white transition-colors">Blog</a></li>
              <li><a href="/about" class="text-sm text-slate-300 hover:text-white transition-colors">About fitness-complete</a></li>
              <li><a href="/privacy-policy" class="text-sm text-slate-300 hover:text-white transition-colors">Privacy Policy</a></li>
            </ul>
          </div>

        </div>

        <!-- Bottom bar -->
        <div class="border-t border-slate-700 pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
          <p class="text-sm font-bold text-white">fitness-complete.com</p>
          <p class="text-xs text-slate-500">This site contains affiliate links. We may earn a commission at no extra cost to you.</p>
          <p class="text-xs text-slate-500">Last updated: March 2026</p>
        </div>
      </div>
    </footer>

    <!-- Cookie banner -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 bg-gray-900 text-white z-50" style="display:none">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-start sm:items-center gap-3 justify-between">
        <p class="text-sm text-gray-300">
          This site uses cookies for analytics. By continuing you accept our
          <a href="/privacy-policy" class="underline hover:text-white transition-colors">Privacy Policy</a>.
        </p>
        <div class="flex gap-3 flex-shrink-0">
          <button
            id="cookie-decline"
            class="border border-slate-600 text-slate-300 text-sm font-semibold px-4 py-2 rounded-lg hover:bg-slate-800 transition-colors"
          >
            Decline
          </button>
          <button
            id="cookie-accept"
            class="bg-white text-gray-900 text-sm font-semibold px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors"
          >
            Accept
          </button>
        </div>
      </div>
    </div>

    <script>
      (function () {
        const toggle = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');
        if (toggle && menu) {
          toggle.addEventListener('click', function () {
            const isOpen = !menu.classList.contains('hidden');
            menu.classList.toggle('hidden');
            toggle.setAttribute('aria-expanded', String(!isOpen));
          });
        }
      })();
    </script>

    <script>
      (function () {
        const banner = document.getElementById('cookie-banner');
        if (!localStorage.getItem('cookieAccepted') && !localStorage.getItem('cookieDeclined')) {
          banner.style.display = 'block';
        }
        document.getElementById('cookie-accept').addEventListener('click', function () {
          localStorage.setItem('cookieAccepted', 'true');
          banner.style.display = 'none';
        });
        document.getElementById('cookie-decline').addEventListener('click', function () {
          localStorage.setItem('cookieDeclined', 'true');
          banner.style.display = 'none';
        });
      })();
    </script>

    <script>
      // Sticky TOC scroll tracking for sport pages
      const sections = document.querySelectorAll('[data-product-section]');
      const tocLinks = document.querySelectorAll('.toc-link');
      if (sections.length > 0 && tocLinks.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                tocLinks.forEach((link) => {
                  link.classList.remove('border-gray-900', 'text-gray-900', 'font-semibold');
                  link.classList.add('border-transparent', 'text-slate-400');
                });
                const activeLink = document.querySelector(`.toc-link[data-section="${entry.target.id}"]`);
                if (activeLink) {
                  activeLink.classList.remove('border-transparent', 'text-slate-400');
                  activeLink.classList.add('border-gray-900', 'text-gray-900', 'font-semibold');
                }
              }
            });
          },
          { rootMargin: '-10% 0px -70% 0px' }
        );
        sections.forEach((section) => observer.observe(section));
      }
    </script>
    <Analytics />
  </body>
</html>
