---
import Layout from '../layouts/Layout.astro';

const sports = [
  {
    name: 'Gym',
    slug: 'gym-starter-set',
    description: 'Gym bag, water bottle, gloves, and a shaker. The five things every beginner actually needs before their first session.',
    accent: 'text-orange-700',
    borderColor: 'border-t-orange-500',
    image: 'https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=800',
    alt: 'Athlete training with weights in a gym',
  },
  {
    name: 'Pilates',
    slug: 'pilates-starter-set',
    description: 'Mat, grip socks, and resistance bands. The essentials for reformer or mat classes, without overbuying.',
    accent: 'text-purple-700',
    borderColor: 'border-t-purple-500',
    image: 'https://images.unsplash.com/photo-1518611012118-696072aa579a?w=800',
    alt: 'Person performing Pilates exercises on a mat',
  },
  {
    name: 'Running',
    slug: 'running-starter-set',
    description: 'The right shoes are 90% of it. Plus what to wear and carry so your first few miles don\'t suck.',
    accent: 'text-green-700',
    borderColor: 'border-t-green-500',
    image: 'https://images.unsplash.com/photo-1476480862126-209bfaa8edc8?w=800',
    alt: 'Runner on an outdoor trail',
  },
  {
    name: 'Home Gym',
    slug: 'home-gym-starter-set',
    description: 'Build a functional setup that doesn\'t take over your living room. Prioritized by what you\'ll actually use.',
    accent: 'text-blue-700',
    borderColor: 'border-t-blue-500',
    image: 'https://images.unsplash.com/photo-1540497077202-7c8a3999166f?w=800',
    alt: 'Home gym setup with dumbbells and exercise equipment',
  },
  {
    name: 'Pickleball',
    slug: 'pickleball-starter-set',
    description: 'Paddle, shoes with lateral support, and the right balls for your surface. Everything a beginner needs before their first game.',
    accent: 'text-teal-700',
    borderColor: 'border-t-teal-500',
    image: 'https://images.unsplash.com/photo-1612872087720-bb876e2e67d1?w=800',
    alt: 'Pickleball paddle and balls on a court',
  },
];
---

<Layout title="Fitness-Complete: Starter Kits for Every Sport">

  <main>

    <!-- Page subtitle -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-5 pb-8">
      <p class="text-sm text-gray-500">Curated starter kits for gym, Pilates, running, home gym, and pickleball. Researched from real beginners.</p>
    </div>

    <!-- Sport category cards -->
    <section id="sports" class="max-w-5xl mx-auto px-4 sm:px-6 pb-12">

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {sports.map((sport) => (
          <a
            href={`/${sport.slug}`}
            class={`group block rounded-xl border border-gray-200 hover:border-gray-300 hover:shadow-md transition-all duration-200 overflow-hidden border-t-4 ${sport.borderColor}`}
          >
            <div class="relative">
              <img
                src={sport.image}
                alt={sport.alt}
                class="h-48 w-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="font-bold text-gray-900 text-base mb-1 group-hover:text-gray-600 transition-colors">
                {sport.name} Starter Kit
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed">{sport.description}</p>
              <span class={`inline-block mt-3 text-xs font-semibold ${sport.accent}`}>
                See the kit →
              </span>
            </div>
          </a>
        ))}

        <!-- Gifts card -->
        <a
          href="/gifts"
          class="group block rounded-xl border border-amber-200 bg-amber-50 hover:border-amber-300 hover:shadow-md transition-all duration-200 overflow-hidden border-t-4 border-t-amber-500"
        >
          <div class="relative">
            <img
              src="https://images.unsplash.com/photo-1513885535751-8b9238bd345a?w=800"
              alt="Gift wrapped present"
              class="h-48 w-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 text-base mb-1 group-hover:text-gray-600 transition-colors">
              Gift Ideas
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed">Shopping for someone else? Find the right gear by sport and budget.</p>
            <span class="inline-block mt-3 text-xs font-semibold text-amber-700">
              See gift picks →
            </span>
          </div>
        </a>
      </div>
    </section>

    <!-- From the blog -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-10 border-t border-gray-100">
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-5">From the blog</p>
      <ul class="space-y-4">
        <li>
          <a href="/blog/how-many-days-per-week-gym-beginner" class="group flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
            <span class="font-semibold text-gray-900 group-hover:text-blue-600 transition-colors text-sm">How Many Days a Week Should a Beginner Go to the Gym?</span>
            <span class="text-sm text-gray-400 mt-0.5 sm:mt-0">The honest answer based on actual research. You need less than you think.</span>
          </a>
        </li>
        <li>
          <a href="/blog/how-to-start-playing-pickleball" class="group flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
            <span class="font-semibold text-gray-900 group-hover:text-blue-600 transition-colors text-sm">How to Start Playing Pickleball: What Nobody Tells Beginners</span>
            <span class="text-sm text-gray-400 mt-0.5 sm:mt-0">Try it before you spend a cent on gear. A practical guide for true beginners.</span>
          </a>
        </li>
      </ul>
    </section>

    <!-- Methodology note -->
    <section class="bg-gray-50 border-t border-gray-100">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
        <p class="text-sm text-gray-600">
          <span class="font-semibold text-gray-900">How we pick:</span> Reddit community consensus, independently tested by Wirecutter and Garage Gym Reviews, Amazon verified purchase patterns. Commission rate plays no role. <a href="/how-we-pick" class="text-blue-600 hover:text-blue-800 underline transition-colors">Full methodology →</a>
        </p>
      </div>
    </section>

  </main>

</Layout>
