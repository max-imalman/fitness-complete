---
import Layout from '../layouts/Layout.astro';

const sports = [
  {
    name: 'Gym',
    slug: 'gym-starter-set',
    description: 'Lifting shoes, belt, straps, and a decent program. Everything a beginner needs to not look lost on day one.',
    accent: 'text-orange-700',
    borderColor: 'border-t-orange-500',
    image: 'https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=800',
    alt: 'Athlete training with weights in a gym',
  },
  {
    name: 'Pilates',
    slug: 'pilates-starter-set',
    description: 'Mat, grip socks, and resistance bands. The essentials for reformer or mat classes, without overbuying.',
    accent: 'text-purple-700',
    borderColor: 'border-t-purple-500',
    image: 'https://images.unsplash.com/photo-1518611012118-696072aa579a?w=800',
    alt: 'Person performing Pilates exercises on a mat',
  },
  {
    name: 'Running',
    slug: 'running-starter-set',
    description: 'The right shoes are 90% of it. Plus what to wear and carry so your first few miles don\'t suck.',
    accent: 'text-green-700',
    borderColor: 'border-t-green-500',
    image: 'https://images.unsplash.com/photo-1476480862126-209bfaa8edc8?w=800',
    alt: 'Runner on an outdoor trail',
  },
  {
    name: 'Home Gym',
    slug: 'home-gym-starter-set',
    description: 'Build a functional setup that doesn\'t take over your living room. Prioritized by what you\'ll actually use.',
    accent: 'text-blue-700',
    borderColor: 'border-t-blue-500',
    image: 'https://images.unsplash.com/photo-1540497077202-7c8a3999166f?w=800',
    alt: 'Home gym setup with dumbbells and exercise equipment',
  },
  {
    name: 'Boxing',
    slug: 'boxing-starter-set',
    description: 'Gloves, wraps, and a bag. The minimum to start training without hurting your hands or wasting money.',
    accent: 'text-red-700',
    borderColor: 'border-t-red-500',
    image: 'https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?w=800',
    alt: 'Boxer training with gloves and heavy bag',
  },
];
---

<Layout title="Fitness-Complete: Starter Kits for Every Sport">

  <main>

    <!-- Hero — dark navy -->
    <section class="bg-[#0f172a]">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-20 pb-16 text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-slate-400 mb-4">Researched. Honest. Beginner-first.</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white leading-tight mb-6">
          The Complete Starter Kit<br class="hidden sm:block" /> for Your Sport
        </h1>
        <p class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto leading-relaxed">
          We researched what beginners actually need. No fluff, no upsells. Just the right gear to get started.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <a href="#sports" class="inline-block bg-white text-gray-900 text-sm font-semibold px-6 py-3 rounded-lg hover:bg-gray-100 transition-colors">
            Browse starter kits
          </a>
          <a href="/gifts" class="inline-block border border-slate-600 text-slate-200 text-sm font-semibold px-6 py-3 rounded-lg hover:border-slate-400 transition-colors">
            Shopping for a gift?
          </a>
        </div>
      </div>
    </section>

    <!-- Hero image -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
      <figure>
        <img
          src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1200"
          alt="Person working out in a well-equipped gym. Photo: Unsplash"
          class="w-full rounded-2xl object-cover max-h-[35vh] sm:max-h-[45vh]"
        />
      </figure>
    </section>

    <!-- Gift angle -->
    <section class="bg-amber-50 border-y border-amber-100">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-12 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="w-1 self-stretch bg-amber-300 rounded-full flex-shrink-0 hidden sm:block"></div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-1">The perfect gift for someone starting out</h2>
          <p class="text-gray-600 text-sm sm:text-base max-w-2xl">
            Got a friend who just signed up for the gym, started Pilates, or wants to try boxing? A starter kit beats a generic gift card. We've put together the exact gear they'll actually need, organized by sport with budget and premium options.
          </p>
          <a href="/gifts" class="inline-block mt-3 text-sm font-semibold text-amber-700 hover:text-amber-900 transition-colors">
            See gift recommendations →
          </a>
        </div>
      </div>
    </section>

    <!-- Sport category cards -->
    <section id="sports" class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-10">Pick your sport</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {sports.map((sport) => (
          <a
            href={`/${sport.slug}`}
            class={`group block rounded-xl border border-gray-200 hover:border-gray-300 hover:shadow-md transition-all duration-200 overflow-hidden border-t-4 ${sport.borderColor}`}
          >
            <div class="relative">
              <img
                src={sport.image}
                alt={sport.alt}
                class="h-48 w-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="font-bold text-gray-900 text-base mb-1 group-hover:text-gray-600 transition-colors">
                {sport.name} Starter Kit
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed">{sport.description}</p>
              <span class={`inline-block mt-3 text-xs font-semibold ${sport.accent}`}>
                See the kit →
              </span>
            </div>
          </a>
        ))}

        <!-- Gifts card -->
        <a
          href="/gifts"
          class="group block rounded-xl border border-amber-200 bg-amber-50 hover:border-amber-300 hover:shadow-md transition-all duration-200 overflow-hidden border-t-4 border-t-amber-500"
        >
          <div class="relative">
            <img
              src="https://images.unsplash.com/photo-1513885535751-8b9238bd345a?w=800"
              alt="Gift wrapped present"
              class="h-48 w-full object-cover"
              loading="lazy"
            />
            <span class="absolute bottom-1 right-2 text-[10px] text-white/60">Photo: Unsplash</span>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 text-base mb-1 group-hover:text-gray-600 transition-colors">
              Gift Ideas
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed">Shopping for someone else? Find the right gear by sport and budget.</p>
            <span class="inline-block mt-3 text-xs font-semibold text-amber-700">
              See gift picks →
            </span>
          </div>
        </a>
      </div>
    </section>

    <!-- Methodology note -->
    <section class="bg-gray-50 border-t border-gray-100">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
        <p class="text-sm text-gray-600">
          <span class="font-semibold text-gray-900">How we pick:</span> Reddit community consensus, independently tested by Wirecutter and Garage Gym Reviews, Amazon verified purchase patterns. Commission rate plays no role. <a href="/how-we-pick" class="text-blue-600 hover:text-blue-800 underline transition-colors">Full methodology →</a>
        </p>
      </div>
    </section>

    <!-- Reddit trust section -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12 border-t border-gray-100">
      <p class="text-sm font-semibold text-gray-500 mb-4">Our picks come from real beginner recommendations, not sponsored content.</p>
      <div class="flex flex-wrap gap-3">
        <span class="inline-flex items-center bg-orange-50 text-orange-700 text-sm font-semibold px-4 py-2 rounded-full border border-orange-100">r/fitness</span>
        <span class="inline-flex items-center bg-orange-50 text-orange-700 text-sm font-semibold px-4 py-2 rounded-full border border-orange-100">r/beginnerfitness</span>
        <span class="inline-flex items-center bg-orange-50 text-orange-700 text-sm font-semibold px-4 py-2 rounded-full border border-orange-100">r/xxfitness</span>
      </div>
    </section>

  </main>

</Layout>
