---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: 'Pilates Mat',
    why: `A yoga mat won't cut it. You need at least 6mm of cushioning or you'll spend the class shifting and grimacing instead of focusing on form.`,
    topPickReason: `Dense enough to protect your spine and knees through a full class, without the instability that extra-thick mats create during standing balance work.`,
    options: [
      { tier: 'Best value', name: 'Gaiam Essentials Thick Yoga Mat', price: '~$29', bestFor: 'Getting started without overspending', link: 'https://www.amazon.com/s?k=Gaiam+Essentials+Thick+Yoga+Mat&tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'Manduka PRO Lite 4.7mm', price: '~$83', bestFor: 'Dense, grippy and built to last, best for most beginners', link: '#', retailer: 'Buy at REI →' },
      { tier: 'Long-term investment', name: 'Lululemon The Mat 5mm', price: '~$108', bestFor: 'Best grip and cushion, looks great in studio', link: '#', retailer: 'Buy at Lululemon →' },
    ],
    score: 'Amazon: 44/50 · Independent tests: 30/35 · Beginner fit: 14/15 · Total: 88/100',
  },
  {
    name: 'Grip Socks',
    why: `Most studios require grip socks and won't let you in without them. The rubber dots prevent slipping on reformer platforms, which matters when you're in a wide squat at full spring tension.`,
    topPickReason: `Individual toe pockets improve your connection to the reformer platform, which is exactly the sensory feedback your instructor is cueing you toward.`,
    options: [
      { tier: 'Best value', name: 'Tavi Noir Savvy Sock', price: '~$14', bestFor: 'Meets studio requirements without the price tag', link: 'https://www.amazon.com/dp/B0B8MM3H8F?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'ToeSox Full Toe Crew', price: '~$21', bestFor: 'Individual toe design improves reformer feedback', link: 'https://www.amazon.com/dp/B0C9QY42DY?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Long-term investment', name: 'Pointe Studio Full Grip Sock', price: '~$31', bestFor: 'Best tested grip sock overall, 5/5 stars in independent testing for workout performance', link: '#', retailer: 'Buy at Pointe Studio →' },
    ],
    score: 'Amazon: 40/50 · Independent tests: 22/35 · Beginner fit: 13/15 · Total: 75/100',
  },
  {
    name: 'Resistance Bands',
    why: `Mat Pilates classes use resistance bands constantly, from arm series to leg work to assisted stretching. Get a set with multiple resistance levels and choose fabric loops over latex for hip work.`,
    topPickReason: `Physical-therapy grade quality means they hold up to daily class use without snapping or losing resistance over time, unlike cheaper latex alternatives.`,
    options: [
      { tier: 'Best value', name: 'Fit Simplify Resistance Loop Bands', price: '~$12', bestFor: '5-band set, covers every resistance level', link: 'https://www.amazon.com/dp/B09MJKJYLQ?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'Theraband Professional Loops', price: '~$21', bestFor: 'Physical-therapy grade, color-coded resistance', link: 'https://www.amazon.com/dp/B00M1WK5Z0?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Long-term investment', name: 'Perform Better Mini Bands', price: '~$31', bestFor: 'Durable fabric, won\'t roll or snap, class staple', link: '#', retailer: 'Buy at Perform Better →' },
    ],
    score: 'Amazon: 43/50 · Independent tests: 25/35 · Beginner fit: 12/15 · Total: 80/100',
  },
  {
    name: 'Water Bottle',
    why: `You need a leakproof bottle because it will get knocked over on the reformer. Get at least 32oz to last a 60-minute class without a refill.`,
    topPickReason: `The leak-proof lid handles being knocked over in a reformer studio and keeps water cold through the full 60 minutes without insulation trade-offs.`,
    options: [
      { tier: 'Best value', name: 'Nalgene Wide Mouth 32oz', price: '~$12', bestFor: 'Indestructible, simple, no frills', link: 'https://www.amazon.com/dp/B002PLU912?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'Hydro Flask 32oz Wide Mouth', price: '~$45', bestFor: 'Keeps water cold, great leakproof lid', link: '#', retailer: 'Buy at REI →' },
      { tier: 'Long-term investment', name: "S'well 17oz Bottle", price: '~$40', bestFor: 'Slim enough for a reformer cupholder, beautiful finish', link: 'https://www.amazon.com/dp/B07CS5SPRW?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
    ],
    score: 'Amazon: 46/50 · Independent tests: 30/35 · Beginner fit: 13/15 · Total: 89/100',
  },
  {
    name: 'Grip Gloves',
    why: `Optional for mat classes, but useful for reformer work where your hands are on smooth bars for extended holds. They prevent callusing and give you more confidence through the arm series.`,
    topPickReason: `The wrist wrap support becomes genuinely useful during the extended reformer bar holds that put repetitive stress on the wrist joint.`,
    options: [
      { tier: 'Best value', name: 'Trideer Half Finger Gloves', price: '~$14', bestFor: 'Basic palm protection, fits most hand sizes', link: 'https://www.amazon.com/dp/B07G8621VX?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'Harbinger Pro Wrist Wrap Gloves', price: '~$35', bestFor: 'Adds wrist support for reformer bar holds', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
      { tier: 'Long-term investment', name: 'Lululemon Fitness Gloves', price: '~$43', bestFor: 'Clean design, great grip, won\'t look out of place in class', link: '#', retailer: 'Buy at Lululemon →' },
    ],
    score: 'Amazon: 42/50 · Independent tests: 28/35 · Beginner fit: 11/15 · Total: 81/100',
  },
];

const slugify = (s: string) => s.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');

const tierColors: Record<string, string> = {
  'Best value': 'bg-green-50 text-green-700',
  'Our pick': 'bg-blue-50 text-blue-700',
  'Long-term investment': 'bg-purple-50 text-purple-700',
};
---

<Layout
  title="Pilates Starter Kit | fitness-complete.com"
  description="What you actually need before your first Pilates class. Researched from Reddit and real reviews, with no influencer picks."
>

  <main>

    <!-- Hero -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-16 pb-8">
      <a href="/" class="inline-block text-sm text-gray-400 hover:text-gray-600 transition-colors mb-6">← All starter kits</a>
      <figure class="mb-5">
        <img
          src="https://images.unsplash.com/photo-1518611012118-696072aa579a?w=800"
          alt="Person performing Pilates exercises on a mat. Photo: Unsplash"
          class="w-full rounded-xl object-cover h-[180px]"
        />
      </figure>
      <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-3">Pilates</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-gray-900 leading-tight mb-5">
        Pilates Starter Kit: What to Buy Before Your First Class
      </h1>
      <p class="text-lg sm:text-xl text-gray-500 max-w-2xl leading-relaxed">
        What you actually need before your first class, and what to skip.
      </p>
    </section>

    <!-- Mobile section nav -->
    <div class="lg:hidden overflow-x-auto border-b border-gray-200 sticky top-0 z-10 bg-[#fafaf8]">
      <div class="flex gap-2 px-4 sm:px-6 py-3">
        {products.map((p) => (
          <a
            href={`#${slugify(p.name)}`}
            class="flex-shrink-0 text-sm font-medium px-4 py-1.5 rounded-full bg-white border border-gray-200 text-gray-600 hover:border-gray-400 hover:text-gray-900 transition-all whitespace-nowrap"
          >
            {p.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Product sections -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 pb-16">
      <div class="space-y-16 pt-12">

          {products.map((product, i) => (
            <div id={slugify(product.name)} data-product-section>
              <div class="flex items-center gap-3 mb-4">
                <span class="bg-gray-900 text-white text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0">
                  {i + 1}
                </span>
                <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900">{product.name}</h2>
              </div>

              <p class="text-gray-600 leading-relaxed mb-5 max-w-3xl">{product.why}</p>

              <!-- Top pick callout -->
              {product.options.filter(o => o.tier === 'Our pick').map(pick => (
                <a href={pick.link !== '#' ? pick.link : (product.options.find(o => o.tier === 'Best value')?.link ?? '#')} target="_blank" rel="noopener noreferrer" class="block no-underline bg-blue-50 border border-blue-100 hover:border-blue-300 rounded-xl p-4 mb-6 transition-colors">
                  <p class="text-xs font-semibold uppercase tracking-wide text-blue-600 mb-1">Our top pick</p>
                  <p class="font-semibold text-gray-900 text-sm flex items-center gap-1.5">
                    {pick.name}
                    <span class="score-tooltip">
                      <span class="score-icon">ⓘ</span>
                      <span class="score-tip">{product.score}</span>
                    </span>
                  </p>
                  <p class="text-sm text-gray-600 mt-1 leading-relaxed">{product.topPickReason}</p>
                </a>
              ))}

              <!-- Comparison table — desktop -->
              <div class="overflow-x-auto overflow-hidden rounded-xl border border-gray-200">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="bg-[#0f172a]">
                      <th class="text-left px-5 py-3 font-semibold text-white w-24">Tier</th>
                      <th class="text-left px-5 py-3 font-semibold text-white">Product</th>
                      <th class="text-left px-5 py-3 font-semibold text-white w-32">Price</th>
                      <th class="text-left px-5 py-3 font-semibold text-white w-24">Link</th>
                    </tr>
                  </thead>
                  <tbody>
                    {product.options.map((opt, j) => (
                      <tr
                        class={`cursor-pointer hover:opacity-90 ${j < product.options.length - 1 ? 'border-b border-gray-100' : ''} ${opt.tier === 'Our pick' ? 'bg-blue-50/40' : 'bg-white'}`}
                        onclick={`window.open('${opt.link !== '#' ? opt.link : (product.options.find(o => o.tier === 'Best value')?.link ?? '')}','_blank','noopener,noreferrer')`}
                      >
                        <td class="px-5 py-3">
                          <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${tierColors[opt.tier]}`}>
                            {opt.tier}
                          </span>
                        </td>
                        <td class="px-5 py-3 font-medium text-gray-900">
                          {opt.tier === 'Our pick' ? (
                            <span class="inline-flex items-center gap-1.5">
                              {opt.name}
                              <span class="score-tooltip">
                                <span class="score-icon">ⓘ</span>
                                <span class="score-tip">{product.score}</span>
                              </span>
                            </span>
                          ) : opt.name}
                        </td>
                        <td class="px-5 py-3 text-gray-500">{opt.price}</td>
                        <td class="px-5 py-3">
                          <a href={opt.link} target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-800 font-semibold transition-colors">
                            {opt.retailer}
                          </a>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          ))}

      </div>
    </section>

    <!-- Methodology footer -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 py-8 border-t border-gray-100">
      <p class="text-xs text-gray-400">How we pick: Amazon verified reviews, independent tests, beginner fit. No commission influence. <a href="/how-we-pick" class="underline hover:text-gray-600 transition-colors">Full methodology →</a></p>
    </section>

    <!-- Gift callout -->
    <section class="bg-amber-50 border-t border-amber-100">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 py-12 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="w-1 self-stretch bg-amber-300 rounded-full flex-shrink-0 hidden sm:block"></div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-1">Gift this kit</h2>
          <p class="text-gray-600 text-sm sm:text-base max-w-2xl">
            Know someone who just signed up for Pilates? A mat and grip socks alone makes a thoughtful, practical gift that shows you actually know what they need. Add a resistance band set and you've covered everything for their first month of classes.
          </p>
          <a href="/gifts" class="inline-block mt-3 text-sm font-semibold text-amber-700 hover:text-amber-900 transition-colors">
            See the full gift guide →
          </a>
        </div>
      </div>
    </section>

  </main>

</Layout>

<style>
  .score-tooltip {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .score-icon {
    color: #9ca3af;
    font-size: 14px;
    cursor: help;
    line-height: 1;
    font-style: normal;
  }
  .score-tip {
    visibility: hidden;
    opacity: 0;
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #1f2937;
    color: #fff;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    padding: 6px 10px;
    border-radius: 6px;
    max-width: 220px;
    width: max-content;
    white-space: normal;
    z-index: 20;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }
  .score-tooltip:hover .score-tip {
    visibility: visible;
    opacity: 1;
  }
</style>
