---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: 'Adjustable Dumbbells',
    why: `A good set of adjustable dumbbells replaces an entire rack and takes up about as much space as a shoebox. Do not buy the cheap ones; flimsy models slip and wobble mid-set, which is dangerous.`,
    topPickReason: `The updated Results Series dial adjustment moves from 5 to 52.5lbs in seconds, which makes drop sets and supersets actually practical instead of a two-minute production.`,
    safetyNote: `If you own the original Bowflex SelectTech 552 (pre-2025), stop using it immediately. It was recalled due to a safety hazard. Visit Bowflex.com for refund information.`,
    options: [
      { tier: 'Best value', name: 'Amazon Basics Adjustable Dumbbell', price: '$40–60', bestFor: 'Single dumbbell, basic adjustment, tight budget', link: 'https://www.amazon.com/dp/B0FC6RZNK2?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'Bowflex Results Series 552 SelectTech', price: '$280–320', bestFor: 'The recalled original 552 has been replaced by this updated Results Series model. Same dial system, same 5-52.5lb range, same beginner-friendly approach. Best adjustable dumbbell for anyone who does not need to lift over 50lbs.', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
      { tier: 'Long-term investment', name: 'POWERBLOCK Elite EXP', price: '$350–430', bestFor: 'More compact than Bowflex, expandable to 90lbs', link: '#', retailer: 'Buy at POWERBLOCK →' },
    ],
    score: 'Amazon: 44/50 · Independent tests: 30/35 · Beginner fit: 14/15 · Total: 88/100',
  },
  {
    name: 'Resistance Bands',
    why: `Bands fill the gaps between dumbbell weights and are essential for warmup work and banded exercises. A set of loop bands plus one long resistance band covers nearly everything, and they're the cheapest thing on this list.`,
    topPickReason: `The door anchor and handle system opens up rows, presses, and cable-style exercises that loop bands alone cannot replicate.`,
    options: [
      { tier: 'Best value', name: 'Fit Simplify Resistance Loop Bands', price: '$10–14', bestFor: 'Five bands covering light to heavy, hard to beat', link: 'https://www.amazon.com/dp/B09MJKJYLQ?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'Bodylastics Stackable Tube Bands', price: '$30–45', bestFor: 'Anchor system for door, handles included, versatile', link: 'https://www.amazon.com/dp/B006O09M4K?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Long-term investment', name: 'SPRI Braided Xertube', price: '$18–28', bestFor: 'Braided cord won\'t snap, longer lasting than latex', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
    ],
    score: 'Amazon: 40/50 · Independent tests: 20/35 · Beginner fit: 12/15 · Total: 72/100',
  },
  {
    name: 'Pull-Up Bar',
    why: `A doorframe pull-up bar unlocks back and bicep training without machines, and it costs $30. Get one that fits over the frame without screwing into the wall.`,
    topPickReason: `More grip positions than the budget option with no permanent installation, so it works in any doorframe and moves with you if you change rooms.`,
    options: [
      { tier: 'Best value', name: 'Iron Gym Total Upper Body Workout Bar', price: '$28–35', bestFor: 'Classic doorframe design, holds up to 300lbs', link: 'https://www.amazon.com/dp/B001ND04U4?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'Perfect Fitness Multi-Gym Doorframe Bar', price: '$35–45', bestFor: 'Better grip positions, sturdier frame, no screws', link: 'https://www.amazon.com/dp/B01LH1FPKK?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Long-term investment', name: 'Rogue Monster Lite Pull-Up Bar', price: '$195–250', bestFor: 'Wall-mounted, permanent, serious training capacity', link: '#', retailer: 'Buy at Rogue Fitness →' },
    ],
    score: 'Amazon: 42/50 · Independent tests: 22/35 · Beginner fit: 13/15 · Total: 77/100',
  },
  {
    name: 'Exercise Mat',
    why: `Hard floors cause wrist, knee, and spine discomfort during floor work, and a mat also protects your floor from dumbbell drops. A 6mm mat handles most exercises; go thicker if you have joint issues.`,
    topPickReason: `The right balance of cushion and surface grip for floor work, at a size that fits most spaces without feeling like you're exercising on a postage stamp.`,
    options: [
      { tier: 'Best value', name: 'BalanceFrom GoYoga All-Purpose Mat', price: '$18–25', bestFor: 'Gets the job done, good thickness for the price', link: 'https://www.amazon.com/dp/B01MQA0EGZ?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'Gaiam Premium 6mm Yoga Mat', price: '$35–45', bestFor: 'Non-slip texture, good cushion, wide enough for most', link: 'https://www.amazon.com/dp/B00FLID5EO?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Long-term investment', name: 'Manduka PRO 6mm Yoga Mat', price: '$120–140', bestFor: 'Dense, no-squish cushion, lifetime guarantee', link: '#', retailer: 'Buy at REI →' },
    ],
    score: 'Amazon: 41/50 · Independent tests: 22/35 · Beginner fit: 11/15 · Total: 74/100',
  },
  {
    name: 'Foam Roller',
    why: `Most beginners skip the foam roller and regret it around week four when their legs feel like concrete. Use it for 5 to 10 minutes after every session on your quads, hamstrings, and upper back.`,
    topPickReason: `The multi-density grid surface penetrates muscle tissue more effectively than flat foam, producing better results on dense areas like quads and IT bands.`,
    options: [
      { tier: 'Best value', name: 'AmazonBasics High-Density Foam Roller', price: '$18–25', bestFor: 'Firm, durable, does exactly what a foam roller should', link: 'https://www.amazon.com/dp/B00XM2MXK8?tag=fitnesscomple-20', retailer: 'Buy on Amazon →' },
      { tier: 'Our pick', name: 'TriggerPoint GRID Foam Roller', price: '$35–45', bestFor: 'Multi-density surface, better myofascial release', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
      { tier: 'Long-term investment', name: 'Hyperice Vyper 3 Vibrating Roller', price: '$180–220', bestFor: 'Vibration speeds recovery, genuinely different experience', link: '#', retailer: 'Buy at Hyperice →' },
    ],
    score: 'Amazon: 45/50 · Independent tests: 30/35 · Beginner fit: 13/15 · Total: 88/100',
  },
];

const slugify = (s: string) => s.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');

const tierColors: Record<string, string> = {
  'Best value': 'bg-green-50 text-green-700',
  'Our pick': 'bg-blue-50 text-blue-700',
  'Long-term investment': 'bg-purple-50 text-purple-700',
};
---

<Layout
  title="Home Gym Starter Kit | fitness-complete.com"
  description="A functional home gym setup that fits in a corner. No treadmill required. Researched from Reddit and real reviews."
>

  <main>

    <!-- Hero -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-16 pb-8">
      <a href="/" class="inline-block text-sm text-gray-400 hover:text-gray-600 transition-colors mb-6">← All starter kits</a>
      <figure class="mb-5">
        <img
          src="https://images.unsplash.com/photo-1540497077202-7c8a3999166f?w=800"
          alt="Home gym setup with dumbbells and exercise equipment. Photo: Unsplash"
          class="w-full rounded-xl object-cover h-[180px]"
        />
      </figure>
      <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-3">Home Gym</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-gray-900 leading-tight mb-5">
        Home Gym Starter Kit: A Corner Setup That Actually Works
      </h1>
      <p class="text-lg sm:text-xl text-gray-500 max-w-2xl leading-relaxed">
        A functional setup that fits in a corner. No treadmill required.
      </p>
    </section>

    <!-- Mobile section nav -->
    <div class="lg:hidden overflow-x-auto border-b border-gray-200 sticky top-0 z-10 bg-[#fafaf8]">
      <div class="flex gap-2 px-4 sm:px-6 py-3">
        {products.map((p) => (
          <a
            href={`#${slugify(p.name)}`}
            class="flex-shrink-0 text-sm font-medium px-4 py-1.5 rounded-full bg-white border border-gray-200 text-gray-600 hover:border-gray-400 hover:text-gray-900 transition-all whitespace-nowrap"
          >
            {p.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Product sections -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 pb-16">
      <div class="space-y-16 pt-12">

          {products.map((product, i) => (
            <div id={slugify(product.name)} data-product-section>
              <div class="flex items-center gap-3 mb-4">
                <span class="bg-gray-900 text-white text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0">
                  {i + 1}
                </span>
                <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900">{product.name}</h2>
              </div>

              <p class="text-gray-600 leading-relaxed mb-5 max-w-3xl">{product.why}</p>

              {product.name === 'Pull-Up Bar' && (
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6">
                  <p class="text-sm text-amber-900"><span class="font-semibold">Note:</span> Doorframe pull-up bars require at least 0.5 inches of door trim overhang to grip onto. Flush-mounted doorframes (no trim visible) will not work. Check your doorframe before buying.</p>
                </div>
              )}

              <!-- Top pick callout -->
              <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 mb-6">
                <p class="text-xs font-semibold uppercase tracking-wide text-blue-600 mb-1">Our top pick</p>
                <p class="font-semibold text-gray-900 text-sm flex items-center gap-1.5">
                  {product.options.find(o => o.tier === 'Our pick')?.name}
                  <span class="score-tooltip">
                    <span class="score-icon">ⓘ</span>
                    <span class="score-tip">{product.score}</span>
                  </span>
                </p>
                <p class="text-sm text-gray-600 mt-1 leading-relaxed">{product.topPickReason}</p>
              </div>

              <!-- Comparison table — desktop -->
              <div class="hidden sm:block overflow-x-auto overflow-hidden rounded-xl border border-gray-200">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="bg-[#0f172a]">
                      <th class="text-left px-5 py-3 font-semibold text-white w-24">Tier</th>
                      <th class="text-left px-5 py-3 font-semibold text-white">Product</th>
                      <th class="text-left px-5 py-3 font-semibold text-white w-32">Price</th>
                      <th class="text-left px-5 py-3 font-semibold text-white w-24">Link</th>
                    </tr>
                  </thead>
                  <tbody>
                    {product.options.map((opt, j) => (
                      <tr class={`${j < product.options.length - 1 ? 'border-b border-gray-100' : ''} ${opt.tier === 'Our pick' ? 'bg-blue-50/40' : 'bg-white'}`}>
                        <td class="px-5 py-3">
                          <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${tierColors[opt.tier]}`}>
                            {opt.tier}
                          </span>
                        </td>
                        <td class="px-5 py-3 font-medium text-gray-900">
                          {opt.name}
                        </td>
                        <td class="px-5 py-3 text-gray-500">{opt.price}</td>
                        <td class="px-5 py-3">
                          <a href={opt.link} class="text-blue-600 hover:text-blue-800 font-semibold transition-colors">
                            {opt.retailer}
                          </a>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              <!-- Comparison cards — mobile -->
              <div class="sm:hidden space-y-3">
                {product.options.map((opt, j) => (
                  <div class={`rounded-xl border p-4 ${opt.tier === 'Our pick' ? 'border-blue-200 bg-blue-50/40' : 'border-gray-100 bg-white'}`}>
                    <div class="flex items-center justify-between mb-2">
                      <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${tierColors[opt.tier]}`}>
                        {opt.tier}
                      </span>
                      <span class="text-sm text-gray-500 font-medium">{opt.price}</span>
                    </div>
                    <div class="mb-1">
                      <p class="font-semibold text-gray-900 text-sm">{opt.name}</p>
                    </div>
                    <p class="text-xs text-gray-500 mb-3">{opt.bestFor}</p>
                    <a href={opt.link} class="inline-block text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors">
                      {opt.retailer}
                    </a>
                  </div>
                ))}
              </div>

              {product.safetyNote && (
                <div class="mt-4 bg-red-50 border border-red-100 rounded-xl px-5 py-4">
                  <p class="text-sm text-red-700 leading-relaxed"><span class="font-semibold">Safety note:</span> {product.safetyNote}</p>
                </div>
              )}
            </div>
          ))}

      </div>
    </section>

    <!-- Methodology footer -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 py-8 border-t border-gray-100">
      <p class="text-xs text-gray-400">How we pick: Amazon verified reviews, independent tests, beginner fit. No commission influence. <a href="/how-we-pick" class="underline hover:text-gray-600 transition-colors">Full methodology →</a></p>
    </section>

    <!-- Gift callout -->
    <section class="bg-amber-50 border-t border-amber-100">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 py-12 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="w-1 self-stretch bg-amber-300 rounded-full flex-shrink-0 hidden sm:block"></div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-1">Gift this kit</h2>
          <p class="text-gray-600 text-sm sm:text-base max-w-2xl">
            Know someone who's been saying they want to work out at home? A resistance band set and a foam roller is a practical, thoughtful gift under $60 that actually gets used. If budget allows, the Bowflex SelectTech 552s are the kind of gift that gets mentioned every time they work out.
          </p>
          <a href="/gifts" class="inline-block mt-3 text-sm font-semibold text-amber-700 hover:text-amber-900 transition-colors">
            See the full gift guide →
          </a>
        </div>
      </div>
    </section>

  </main>

</Layout>

<style>
  .score-tooltip {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .score-icon {
    color: #9ca3af;
    font-size: 14px;
    cursor: help;
    line-height: 1;
    font-style: normal;
  }
  .score-tip {
    visibility: hidden;
    opacity: 0;
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #1f2937;
    color: #fff;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    padding: 6px 10px;
    border-radius: 6px;
    max-width: 220px;
    width: max-content;
    white-space: normal;
    z-index: 20;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }
  .score-tooltip:hover .score-tip {
    visibility: visible;
    opacity: 1;
  }
</style>
