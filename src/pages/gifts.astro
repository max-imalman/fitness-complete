const tierColors: Record<string, string> = {
  Budget: 'bg-green-50 text-green-700',
  'Mid-Range': 'bg-blue-50 text-blue-700',
  Premium: 'bg-purple-50 text-purple-700',
};
---

<Layout
  title="Fitness Gift Ideas | fitness-complete.com"
  description="The perfect gift for someone starting out. Curated fitness gift picks by sport and budget, from under $50 to serious splurges."
>

  <main>

    <!-- Hero -->
    <section class="bg-[#0f172a]">
      <div class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-20 pb-16">
        <a href="/" class="inline-block text-sm text-slate-400 hover:text-slate-200 transition-colors mb-8">← All starter kits</a>
        <p class="text-sm font-semibold uppercase tracking-widest text-slate-400 mb-4">Gift Ideas</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white leading-tight mb-5 max-w-3xl">
          The perfect gift for someone starting out
        </h1>
        <p class="text-lg sm:text-xl text-slate-300 max-w-2xl leading-relaxed">
          A gym membership without the gear is half a gift. Here are our top picks by sport and budget.
        </p>
      </div>
    </section>

    <!-- Under $50 callout -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 pt-12 pb-8">
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 sm:p-8">
        <div class="mb-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-amber-600 mb-1">Quick picks</p>
          <h2 class="text-xl font-extrabold text-gray-900">Under $50, by sport</h2>
          <p class="text-sm text-gray-500 mt-1">One practical gift for every sport, all under $50.</p>
        </div>
        <ul class="space-y-0 divide-y divide-amber-100">
          {underFifty.map((item) => (
            <li class={`flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-4 py-4 border-l-4 pl-4 ${item.borderColor}`}>
              <span class={`text-xs font-bold uppercase tracking-wide ${item.accent} sm:w-20 flex-shrink-0 pt-0.5`}>{item.sport}</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-gray-900">{item.pick}</p>
                <p class="text-xs text-gray-500 mt-0.5">{item.note}</p>
              </div>
              <div class="flex items-center gap-3 sm:flex-col sm:items-end flex-shrink-0">
                <span class="text-sm font-semibold text-gray-700">{item.price}</span>
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-blue-600 hover:text-blue-800 transition-colors whitespace-nowrap">{item.retailer} →</a>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Sport sections -->
    <section class="max-w-[1400px] mx-auto px-4 sm:px-6 pb-16 space-y-12 pt-6">

      {sportGifts.map((sport) => (
        <div class={`rounded-2xl border border-gray-200 overflow-hidden border-t-4 ${sport.borderColor}`}>

          <!-- Sport header -->
          <div class="px-6 sm:px-8 pt-7 pb-5 border-b border-gray-100">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-2xl font-extrabold text-gray-900 mb-1">{sport.name}</h2>
                <p class="text-gray-500 text-sm max-w-2xl">{sport.giftAngle}</p>
              </div>
              <a href={`/${sport.slug}`} class={`flex-shrink-0 text-xs font-semibold ${sport.accent} hover:opacity-75 transition-opacity whitespace-nowrap hidden sm:block`}>
                Full kit →
              </a>
            </div>
          </div>

          <div class="px-6 sm:px-8 py-6 space-y-5">

            <!-- Featured pick -->
            <div class="bg-blue-50 border border-blue-100 rounded-xl p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-blue-600 mb-1">Our top gift pick</p>
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="font-semibold text-gray-900 text-sm">{sport.featured.name}</p>
                  <p class="text-sm text-gray-600 mt-1 max-w-xl">{sport.featured.why}</p>
                </div>
                <div class="flex-shrink-0 text-right">
                  <p class="text-sm font-semibold text-gray-700">{sport.featured.price}</p>
                  <a href={sport.featured.link} target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-blue-600 hover:text-blue-800 transition-colors whitespace-nowrap">{sport.featured.retailer}</a>
                </div>
              </div>
            </div>

            <!-- Gift tiers -->
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">All budget levels</p>
              <ul class="space-y-0 divide-y divide-gray-100">
                {sport.tiers.map((tier) => (
                  <li class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 py-3">
                    <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full flex-shrink-0 self-start ${tierColors[tier.tier]}`}>
                      {tier.tier}
                    </span>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-gray-900">{tier.name}</p>
                      <p class="text-xs text-gray-400">{tier.range}</p>
                    </div>
                    <div class="flex items-center gap-3 sm:flex-col sm:items-end flex-shrink-0">
                      <span class="text-sm text-gray-600 font-medium">{tier.price}</span>
                      <a href={tier.link} target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-blue-600 hover:text-blue-800 transition-colors whitespace-nowrap">{tier.retailer}</a>
                    </div>
                  </li>
                ))}
              </ul>
            </div>

            <a href={`/${sport.slug}`} class={`inline-block text-sm font-semibold ${sport.accent} hover:opacity-75 transition-opacity sm:hidden`}>
              See the full {sport.name} kit →
            </a>

          </div>
        </div>
      ))}

    </section>


  </main>

</Layout>
