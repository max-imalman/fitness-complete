---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: 'Gym Bag',
    why: `You need somewhere to put your stuff that isn't a plastic grocery bag. A dedicated gym bag keeps your sweaty gear contained, makes you less likely to forget things, and signals to your brain that this is a real habit. Get one with a separate shoe compartment. It matters more than you'd expect.`,
    topPickReason: `The most recommended gym bag on Reddit: water-resistant, holds everything including shoes, and built to survive daily gym commutes without falling apart.`,
    options: [
      { tier: 'Budget', name: 'FocusGear Ultimate Gym Bag 2.0', price: '$35–45', bestFor: 'Best tested budget bag, wet pockets and shoe compartment, CNN Underscored pick', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Under Armour Undeniable 5.0 Duffel', price: '$45–55', bestFor: 'Most recommended on Reddit, water-resistant, holds up for years', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
      { tier: 'Premium', name: 'Aer Gym Duffel 3', price: '$145–165', bestFor: 'Gym/work crossover, ventilated shoe compartment, laptop sleeve', link: '#', retailer: 'Buy at Aer.io →' },
    ],
  },
  {
    name: 'Water Bottle',
    why: `Hydration directly affects how hard you can train and how fast you recover. A gym water bottle needs to be large (at least 32oz), leak-proof in your bag, and easy to drink from with one hand. Don't overthink it, but don't use a flimsy bottle that leaks on your shoes either.`,
    topPickReason: `The Owala FreeSip replaced the Hydro Flask as our mid-range pick because it solves the single biggest gym bottle problem: drinking one-handed between sets without unscrewing a cap.`,
    options: [
      { tier: 'Budget', name: 'Nalgene Wide Mouth 32oz', price: '$10–15', bestFor: 'No-nonsense, nearly indestructible', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Owala FreeSip 32oz', price: '$35–45', bestFor: 'Current community favorite, dual drinking options, leakproof, dishwasher safe', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Premium', name: 'YETI Rambler 36oz Bottle', price: '$50–60', bestFor: 'Best insulation, premium feel, lifetime warranty', link: '#', retailer: 'Buy at YETI.com →' },
    ],
  },
  {
    name: 'Workout Gloves',
    why: `Calluses are inevitable, but tearing your palms on the bar in week two is avoidable. Gloves protect your hands while you build grip strength and callus tolerance. Go thin. Thick padded gloves reduce grip feedback. Most beginners who skip gloves early regret it.`,
    topPickReason: `The built-in wrist wrap adds support that standalone gloves lack, which matters most in your first weeks when your wrists are still adapting to the load.`,
    options: [
      { tier: 'Budget', name: 'Ihuan Breathable Fingerless Lifting Gloves', price: '$15–20', bestFor: 'Tested best overall gym glove at this price, designed for lifting not work', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Harbinger Pro Wrist Wrap Gloves', price: '$30–40', bestFor: 'Best combo of protection + wrist support', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
      { tier: 'Premium', name: 'Versa Gripps Classic', price: '$45–60', bestFor: 'Doubles as lifting straps, serious lifters', link: '#', retailer: 'Buy at Rogue Fitness →' },
    ],
  },
  {
    name: 'Shaker Bottle',
    why: `Protein shakes are the easiest way to hit your protein targets without eating a fourth chicken breast. A good shaker blends powder smooth without clumps and doesn't stink after one use. The BlenderBall wire whisk design is the standard. Any shaker without it is a downgrade.`,
    topPickReason: `The dual compartment lets you pre-load your protein and pre-workout separately, so you're not juggling two bottles or mixing at the gym.`,
    options: [
      { tier: 'Budget', name: 'BlenderBottle Classic 28oz', price: '$10–12', bestFor: 'The reliable standard, hard to beat at this price', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Hydra Cup Dual Shaker', price: '$18–22', bestFor: 'Carry pre-workout + shake in one bottle', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Premium', name: 'Promixx MiiXR Electric Shaker', price: '$35–45', bestFor: 'Battery-powered mixing, no lumps ever', link: '#', retailer: 'Buy at Promixx.com →' },
    ],
  },
  {
    name: 'Gym Towel',
    why: `Most gyms require them and the rest should. Wiping down equipment is basic gym etiquette, and having your own means you're not using the grimy communal ones. Get a microfiber towel. It's lighter, dries faster, and takes up less space in your bag than a regular bath towel.`,
    topPickReason: `Better absorbency than budget options and the clip loop means it stays attached to your bag or machine instead of ending up on the floor.`,
    options: [
      { tier: 'Budget', name: 'AmazonBasics Microfiber Towel', price: '$8–12', bestFor: 'Gets the job done, packs small', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Rainleaf Microfiber Gym Towel', price: '$15–20', bestFor: 'Great absorbency, comes with clip loop', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Premium', name: 'Youphoria Sport Towel', price: '$22–28', bestFor: 'Antimicrobial, stays fresh longer, large size', link: '#', retailer: 'Buy on Amazon →' },
    ],
  },
];

const tierColors: Record<string, string> = {
  Budget: 'bg-green-50 text-green-700',
  'Mid-Range': 'bg-blue-50 text-blue-700',
  Premium: 'bg-purple-50 text-purple-700',
};
---

<Layout
  title="Gym Starter Kit | fitness-complete.com"
  description="The exact gear a beginner needs for their first 90 days at the gym. Researched from Reddit and real Amazon reviews, with no influencer picks."
>

  <!-- Nav -->
  <header class="border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-lg font-bold tracking-tight text-gray-900">fitness-complete</a>
      <nav class="hidden sm:flex gap-6 text-sm text-gray-500">
        <a href="/gym-starter-set" class="text-gray-900 font-semibold transition-colors">Gym</a>
        <a href="/pilates-starter-set" class="hover:text-gray-900 transition-colors">Pilates</a>
        <a href="/running-starter-set" class="hover:text-gray-900 transition-colors">Running</a>
        <a href="/home-gym-starter-set" class="hover:text-gray-900 transition-colors">Home Gym</a>
        <a href="/boxing-starter-set" class="hover:text-gray-900 transition-colors">Boxing</a>
        <a href="/gifts" class="hover:text-gray-900 transition-colors font-medium text-gray-700">🎁 Gifts</a>
      </nav>
    </div>
  </header>

  <main>

    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12">
      <a href="/" class="inline-block text-sm text-gray-400 hover:text-gray-600 transition-colors mb-6">← All starter kits</a>
      <figure class="mb-8">
        <img
          src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=800"
          alt="Athlete training with weights in a gym"
          class="w-full rounded-2xl object-cover max-h-[400px]"
        />
        <figcaption class="text-xs text-gray-400 mt-2">Photo: Unsplash</figcaption>
      </figure>
      <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-3">Gym / Weightlifting</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-gray-900 leading-tight mb-5">
        Gym Starter Kit
      </h1>
      <p class="text-lg sm:text-xl text-gray-500 max-w-2xl leading-relaxed">
        What you actually need for your first 90 days. Researched from real beginners, not gym influencers.
      </p>
    </section>

    <!-- Methodology intro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12">
      <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
        <h2 class="font-bold text-gray-900 mb-2">How these picks were made</h2>
        <p class="text-sm text-gray-500 leading-relaxed max-w-3xl">
          These picks were researched across four sources: Reddit community discussions, independent test sites (Garage Gym Reviews, CNN Underscored, Wirecutter), Amazon verified purchase reviews filtered for 3-star honesty and long-term durability, and YouTube reviews from channels without sponsorship conflicts. Commission rate played no role.
        </p>
      </div>
    </section>

    <!-- Product sections -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16 space-y-16">

      {products.map((product, i) => (
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-gray-900 text-white text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0">
              {i + 1}
            </span>
            <h2 class="text-2xl font-bold text-gray-900">{product.name}</h2>
          </div>

          <p class="text-gray-600 leading-relaxed mb-5 max-w-3xl">{product.why}</p>

          <!-- Top pick callout -->
          <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 mb-6">
            <p class="text-xs font-semibold uppercase tracking-wide text-blue-600 mb-1">Our top pick</p>
            <p class="font-semibold text-gray-900 text-sm">{product.options[1].name}</p>
            <p class="text-sm text-gray-600 mt-1">{product.topPickReason}</p>
          </div>

          <!-- Comparison table — desktop -->
          <div class="hidden sm:block overflow-hidden rounded-xl border border-gray-100">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-100">
                  <th class="text-left px-5 py-3 font-semibold text-gray-500 w-24">Tier</th>
                  <th class="text-left px-5 py-3 font-semibold text-gray-500">Product</th>
                  <th class="text-left px-5 py-3 font-semibold text-gray-500 w-32">Price</th>
                  <th class="text-left px-5 py-3 font-semibold text-gray-500">Best For</th>
                  <th class="text-left px-5 py-3 font-semibold text-gray-500 w-24">Link</th>
                </tr>
              </thead>
              <tbody>
                {product.options.map((opt, j) => (
                  <tr class={j < product.options.length - 1 ? 'border-b border-gray-100' : ''}>
                    <td class="px-5 py-4">
                      <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${tierColors[opt.tier]}`}>
                        {opt.tier}
                      </span>
                    </td>
                    <td class="px-5 py-4 font-medium text-gray-900">{opt.name}</td>
                    <td class="px-5 py-4 text-gray-500">{opt.price}</td>
                    <td class="px-5 py-4 text-gray-500">{opt.bestFor}</td>
                    <td class="px-5 py-4">
                      <a href={opt.link} class="text-blue-600 hover:text-blue-800 font-semibold transition-colors">
                        {opt.retailer}
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- Comparison cards — mobile -->
          <div class="sm:hidden space-y-3">
            {product.options.map((opt) => (
              <div class="rounded-xl border border-gray-100 p-4">
                <div class="flex items-center justify-between mb-2">
                  <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${tierColors[opt.tier]}`}>
                    {opt.tier}
                  </span>
                  <span class="text-sm text-gray-500 font-medium">{opt.price}</span>
                </div>
                <p class="font-semibold text-gray-900 text-sm mb-1">{opt.name}</p>
                <p class="text-xs text-gray-500 mb-3">{opt.bestFor}</p>
                <a href={opt.link} class="inline-block text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors">
                  {opt.retailer}
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}

    </section>

    <!-- Gift callout -->
    <section class="bg-amber-50 border-t border-amber-100">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="w-1 self-stretch bg-amber-300 rounded-full flex-shrink-0 hidden sm:block"></div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-1">Gift this kit</h2>
          <p class="text-gray-600 text-sm sm:text-base max-w-2xl">
            Know someone who just got a gym membership? A bag, bottle, and a pair of gloves is a better gift than a gift card. It shows you thought about what they actually need. Pick one item or build the whole kit from the options above.
          </p>
          <a href="/gifts" class="inline-block mt-3 text-sm font-semibold text-amber-700 hover:text-amber-900 transition-colors">
            See the full gift guide →
          </a>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 space-y-4">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <p class="text-sm font-bold text-gray-900">fitness-complete.com</p>
        <div class="flex gap-5 text-xs">
          <a href="/about" class="text-gray-400 hover:text-gray-600 transition-colors">About</a>
          <a href="/privacy-policy" class="text-gray-400 hover:text-gray-600 transition-colors">Privacy Policy</a>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
        <p class="text-xs text-gray-400">This site contains affiliate links. We may earn a commission at no extra cost to you.</p>
        <p class="text-xs text-gray-400">Last updated: March 2026</p>
      </div>
    </div>
  </footer>

</Layout>
