---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: 'Running Shoes',
    why: `This is the single most important purchase you'll make as a beginner runner. The wrong shoe causes injuries — shin splints, knee pain, plantar fasciitis — that end runs before habits form. Get fitted at a local running specialty store if you can (they'll watch you walk and recommend based on your gait). If you're ordering online, at least know whether you overpronate.`,
    options: [
      { tier: 'Budget', name: 'ASICS Gel-Contend 8', price: '$55–70', bestFor: 'Reliable cushion, neutral, great entry price', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Brooks Ghost 16', price: '$130–140', bestFor: 'Best all-rounder for most beginners, smooth ride', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
      { tier: 'Premium', name: 'HOKA Clifton 9', price: '$145–160', bestFor: 'Maximum cushion, ideal for high mileage or joint issues', link: '#', retailer: 'Buy at REI →' },
    ],
  },
  {
    name: 'Running Socks',
    why: `Cotton socks cause blisters. This is not a preference — it's physics. Cotton holds moisture against your skin, which creates friction, which creates blisters. Moisture-wicking synthetic or merino wool socks fix this entirely. Most beginners learn this the hard way after their second run.`,
    options: [
      { tier: 'Budget', name: 'Balega Hidden Comfort No-Show', price: '$14–18', bestFor: 'Best value running sock, cushioned heel and toe', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Darn Tough Run No Show Tab', price: '$22–26', bestFor: 'Merino wool, lifetime warranty, extremely durable', link: '#', retailer: 'Buy at REI →' },
      { tier: 'Premium', name: 'Stance Run Tab', price: '$20–28', bestFor: 'Performance fit, great arch support, premium feel', link: '#', retailer: 'Buy at Stance →' },
    ],
  },
  {
    name: 'Running Belt / Hydration',
    why: `You need somewhere to put your phone, keys, and cards that isn't your hand. Holding your phone changes your arm swing and throws off your form. A running belt solves this cleanly — get one that fits your phone model snugly and doesn't bounce. For runs over 45 minutes, add a handheld water bottle or upgrade to a vest.`,
    options: [
      { tier: 'Budget', name: 'FlipBelt Classic', price: '$28–35', bestFor: 'Minimalist tube belt, no bounce, holds most phones', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Nathan SpeedShot Plus Handheld', price: '$30–38', bestFor: 'Adds hydration for longer runs, hands-free grip', link: '#', retailer: 'Buy at REI →' },
      { tier: 'Premium', name: 'Salomon Active Skin 4 Vest', price: '$120–140', bestFor: 'Full hydration vest for serious distance runners', link: '#', retailer: 'Buy at REI →' },
    ],
  },
  {
    name: 'Moisture-Wicking Shirt',
    why: `Cotton shirts become heavy, cold, and chafe-inducing once they're wet — which happens within ten minutes of running. Synthetic fabrics move sweat away from your skin and dry fast. This doesn't need to be expensive: a $25 tech tee does everything a $90 one does for a beginner. Buy at least two so you're not doing laundry before every run.`,
    options: [
      { tier: 'Budget', name: "Amazon Essentials Men's Tech Stretch Tee", price: '$14–18', bestFor: 'Functional, cheap, buy three and move on', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Nike Dri-FIT Short Sleeve', price: '$30–40', bestFor: 'Great fit, wide size range, reliable wicking', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
      { tier: 'Premium', name: 'Patagonia Capilene Cool Daily', price: '$45–55', bestFor: 'Recycled fabric, odor-resistant, sustainably made', link: '#', retailer: 'Buy at REI →' },
    ],
  },
];

const tierColors: Record<string, string> = {
  Budget: 'bg-green-50 text-green-700',
  'Mid-Range': 'bg-blue-50 text-blue-700',
  Premium: 'bg-purple-50 text-purple-700',
};
---

<Layout
  title="Running Starter Kit — fitness-complete.com"
  description="The right shoes are 90% of it. Here's everything a beginner runner actually needs — researched from Reddit and real reviews."
>

  <!-- Nav -->
  <header class="border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-lg font-bold tracking-tight text-gray-900">fitness-complete</a>
      <nav class="hidden sm:flex gap-6 text-sm text-gray-500">
        <a href="/gym-starter-set" class="hover:text-gray-900 transition-colors">Gym</a>
        <a href="/pilates-starter-set" class="hover:text-gray-900 transition-colors">Pilates</a>
        <a href="/running-starter-set" class="text-gray-900 font-semibold transition-colors">Running</a>
        <a href="/home-gym-starter-set" class="hover:text-gray-900 transition-colors">Home Gym</a>
        <a href="/boxing-starter-set" class="hover:text-gray-900 transition-colors">Boxing</a>
        <a href="/gifts" class="hover:text-gray-900 transition-colors font-medium text-gray-700">🎁 Gifts</a>
        <a href="/about" class="hover:text-gray-900 transition-colors">About</a>
        <a href="/privacy-policy" class="hover:text-gray-900 transition-colors">Privacy</a>
      </nav>
    </div>
  </header>

  <main>

    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12">
      <a href="/" class="inline-block text-sm text-gray-400 hover:text-gray-600 transition-colors mb-6">← All starter kits</a>
      <div class="bg-green-100 h-48 sm:h-64 rounded-2xl w-full flex items-center justify-center mb-8">
        <span class="text-green-400 text-sm font-semibold">Running — image placeholder</span>
      </div>
      <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-3">Running</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-gray-900 leading-tight mb-5">
        Running Starter Kit
      </h1>
      <p class="text-lg sm:text-xl text-gray-500 max-w-2xl leading-relaxed">
        The right shoes are 90% of it. Here's the other 10%.
      </p>
    </section>

    <!-- Methodology intro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12">
      <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
        <h2 class="font-bold text-gray-900 mb-2">How these picks were made</h2>
        <p class="text-sm text-gray-500 leading-relaxed max-w-3xl">
          We pulled from r/running, r/beginnerfitness, and r/C25K to find what beginning runners actually buy and stick with — and what gets returned after two runs. Every pick was cross-referenced with Amazon reviews, specifically filtering for long-term durability and beginner feedback. Commission rate played no role.
        </p>
      </div>
    </section>

    <!-- Product sections -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16 space-y-16">

      {products.map((product, i) => (
        <div>
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-gray-900 text-white text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0">
              {i + 1}
            </span>
            <h2 class="text-2xl font-bold text-gray-900">{product.name}</h2>
          </div>

          <p class="text-gray-600 leading-relaxed mb-6 max-w-3xl">{product.why}</p>

          <!-- Comparison table — desktop -->
          <div class="hidden sm:block overflow-hidden rounded-xl border border-gray-100">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-100">
                  <th class="text-left px-5 py-3 font-semibold text-gray-500 w-24">Tier</th>
                  <th class="text-left px-5 py-3 font-semibold text-gray-500">Product</th>
                  <th class="text-left px-5 py-3 font-semibold text-gray-500 w-32">Price</th>
                  <th class="text-left px-5 py-3 font-semibold text-gray-500">Best For</th>
                  <th class="text-left px-5 py-3 font-semibold text-gray-500 w-24">Link</th>
                </tr>
              </thead>
              <tbody>
                {product.options.map((opt, j) => (
                  <tr class={j < product.options.length - 1 ? 'border-b border-gray-100' : ''}>
                    <td class="px-5 py-4">
                      <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${tierColors[opt.tier]}`}>
                        {opt.tier}
                      </span>
                    </td>
                    <td class="px-5 py-4 font-medium text-gray-900">{opt.name}</td>
                    <td class="px-5 py-4 text-gray-500">{opt.price}</td>
                    <td class="px-5 py-4 text-gray-500">{opt.bestFor}</td>
                    <td class="px-5 py-4">
                      <a href={opt.link} class="text-blue-600 hover:text-blue-800 font-semibold transition-colors">
                        {opt.retailer}
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- Comparison cards — mobile -->
          <div class="sm:hidden space-y-3">
            {product.options.map((opt) => (
              <div class="rounded-xl border border-gray-100 p-4">
                <div class="flex items-center justify-between mb-2">
                  <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${tierColors[opt.tier]}`}>
                    {opt.tier}
                  </span>
                  <span class="text-sm text-gray-500 font-medium">{opt.price}</span>
                </div>
                <p class="font-semibold text-gray-900 text-sm mb-1">{opt.name}</p>
                <p class="text-xs text-gray-500 mb-3">{opt.bestFor}</p>
                <a href={opt.link} class="inline-block text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors">
                  {opt.retailer}
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}

    </section>

    <!-- Gift callout -->
    <section class="bg-amber-50 border-t border-amber-100">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="w-1 self-stretch bg-amber-300 rounded-full flex-shrink-0 hidden sm:block"></div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-1">Gift this kit</h2>
          <p class="text-gray-600 text-sm sm:text-base max-w-2xl">
            Know someone who just signed up for a 5K or started the Couch to 5K program? Running socks and a FlipBelt make a surprisingly thoughtful gift — it shows you know what they actually need on a run. Pair with the Brooks Ghost shoes if you know their size and you've covered everything.
          </p>
          <a href="/gifts" class="inline-block mt-3 text-sm font-semibold text-amber-700 hover:text-amber-900 transition-colors">
            See the full gift guide →
          </a>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-sm font-bold text-gray-900">fitness-complete.com</p>
      <p class="text-xs text-gray-400 max-w-md text-left sm:text-right">
        This site contains affiliate links. We may earn a commission at no extra cost to you.
      </p>
    </div>
  </footer>

</Layout>
