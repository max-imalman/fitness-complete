---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    name: 'Running Shoes',
    why: `This is the single most important purchase you'll make as a beginner runner. The wrong shoe causes shin splints, knee pain, and plantar fasciitis that end runs before habits form.`,
    topPickReason: `The most consistently recommended beginner shoe across running communities because the neutral cushion and smooth heel-to-toe transition works for most gaits without overpromising.`,
    options: [
      { tier: 'Budget', name: 'ASICS Gel-Contend 8', price: '$55–70', bestFor: 'Reliable cushion, neutral, great entry price. Get fitted at a running specialty store like Fleet Feet if possible. Shoe fit is personal and the right model depends on your gait.', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Brooks Ghost 17', price: '$130–140', bestFor: 'Best all-rounder for most beginners, smooth ride', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
      { tier: 'Premium', name: 'HOKA Clifton 10', price: '$145–160', bestFor: 'Maximum cushion, ideal for high mileage or joint issues', link: '#', retailer: 'Buy at REI →' },
    ],
    score: 'Amazon: 47/50 · Independent tests: 35/35 · Beginner fit: 15/15 · Total: 97/100',
  },
  {
    name: 'Running Socks',
    why: `Cotton socks cause blisters because they hold moisture against your skin. Switch to moisture-wicking synthetic or merino wool socks and you will not have this problem.`,
    topPickReason: `Merino wool handles moisture and odor better than synthetics, and the lifetime warranty means you buy running socks exactly once.`,
    options: [
      { tier: 'Budget', name: 'Balega Hidden Comfort No-Show', price: '$14–18', bestFor: 'Best value running sock, cushioned heel and toe', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Darn Tough Run No Show Tab', price: '$22–26', bestFor: 'Merino wool, lifetime warranty, extremely durable', link: '#', retailer: 'Buy at REI →' },
      { tier: 'Premium', name: 'Stance Run Tab', price: '$20–28', bestFor: 'Performance fit, great arch support, premium feel', link: '#', retailer: 'Buy at Stance →' },
    ],
    score: 'Amazon: 45/50 · Independent tests: 33/35 · Beginner fit: 13/15 · Total: 91/100',
  },
  {
    name: 'Running Belt / Hydration',
    why: `You need somewhere to put your phone, keys, and cards that is not your hand. Holding your phone changes your arm swing and throws off your form.`,
    topPickReason: `Combines phone and key storage with a water bottle for longer runs, solving two problems with one purchase instead of buying separately.`,
    options: [
      { tier: 'Budget', name: 'FlipBelt Classic', price: '$28–35', bestFor: 'Minimalist tube belt, no bounce, holds most phones', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Nathan SpeedShot Plus Handheld', price: '$30–38', bestFor: 'Adds hydration for longer runs, hands-free grip', link: '#', retailer: 'Buy at REI →' },
      { tier: 'Premium', name: 'Salomon Active Skin 4 Vest', price: '$120–140', bestFor: 'Full hydration vest for serious distance runners', link: '#', retailer: 'Buy at REI →' },
    ],
    score: 'Amazon: 38/50 · Independent tests: 25/35 · Beginner fit: 12/15 · Total: 75/100',
  },
  {
    name: 'Moisture-Wicking Shirt',
    why: `Cotton shirts become heavy, cold, and chafe-inducing once wet, which happens within ten minutes of running. Synthetic tech fabric solves this and does not need to be expensive.`,
    topPickReason: `Reliable moisture-wicking in a wide size range with men's and women's cuts available, cheap enough to buy two at once without overthinking it.`,
    options: [
      { tier: 'Budget', name: "Amazon Essentials Men's Tech Stretch Tee", price: '$14–18', bestFor: 'Functional, cheap, buy three and move on', link: '#', retailer: 'Buy on Amazon →' },
      { tier: 'Mid-Range', name: 'Nike Dri-FIT Short Sleeve', price: '$30–40', bestFor: 'Great fit, wide size range, reliable wicking', link: '#', retailer: "Buy at Dick's Sporting Goods →" },
      { tier: 'Premium', name: 'Patagonia Capilene Cool Daily', price: '$45–55', bestFor: 'Recycled fabric, odor-resistant, sustainably made', link: '#', retailer: 'Buy at REI →' },
    ],
    score: 'Amazon: 43/50 · Independent tests: 20/35 · Beginner fit: 13/15 · Total: 76/100',
  },
];

const slugify = (s: string) => s.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');

const tierColors: Record<string, string> = {
  Budget: 'bg-green-50 text-green-700',
  'Mid-Range': 'bg-blue-50 text-blue-700',
  Premium: 'bg-purple-50 text-purple-700',
};
---

<Layout
  title="Running Starter Kit | fitness-complete.com"
  description="The right shoes are 90% of it. Here's everything a beginner runner actually needs, researched from Reddit and real reviews."
>

  <main>

    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12">
      <a href="/" class="inline-block text-sm text-gray-400 hover:text-gray-600 transition-colors mb-6">← All starter kits</a>
      <figure class="mb-8">
        <img
          src="https://images.unsplash.com/photo-1476480862126-209bfaa8edc8?w=800"
          alt="Runner on an outdoor trail. Photo: Unsplash"
          class="w-full rounded-2xl object-cover max-h-[35vh] sm:max-h-[45vh]"
        />
      </figure>
      <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-3">Running</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-gray-900 leading-tight mb-5">
        Running Starter Kit: Start Here, Not With the Expensive Stuff
      </h1>
      <p class="text-lg sm:text-xl text-gray-500 max-w-2xl leading-relaxed">
        The right shoes are 90% of it. Here's the other 10%.
      </p>
    </section>

    <!-- Methodology intro -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12">
      <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
        <h2 class="font-bold text-gray-900 mb-2">How these picks were made</h2>
        <p class="text-sm text-gray-500 leading-relaxed max-w-3xl">
          Researched across Reddit communities, independent test sites, and Amazon verified purchase reviews. Commission rate played no role.
        </p>
      </div>
    </section>

    <!-- Bundle callout -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-10">
      <div class="bg-[#0f172a] rounded-xl p-6 sm:p-8">
        <h2 class="text-lg font-bold text-white mb-1">The Complete Running Starter Kit</h2>
        <p class="text-sm text-slate-400 mb-5 max-w-2xl">Want everything at once? Here are our top picks across all {products.length} categories — one choice per category, no decision fatigue.</p>
        <ul class="space-y-0">
          {products.map((p) => (
            <li class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 py-3 border-b border-slate-800 last:border-0">
              <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 sm:w-36 flex-shrink-0">{p.name}</span>
              <span class="text-sm font-medium text-white">{p.options[1].name}</span>
              <a href={p.options[1].link} class="text-xs font-semibold text-blue-400 hover:text-blue-300 transition-colors sm:ml-auto flex-shrink-0 whitespace-nowrap">{p.options[1].retailer}</a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Mobile section nav -->
    <div class="lg:hidden overflow-x-auto border-b border-gray-200 sticky top-0 z-10 bg-[#fafaf8]">
      <div class="flex gap-2 px-4 sm:px-6 py-3">
        {products.map((p) => (
          <a
            href={`#${slugify(p.name)}`}
            class="flex-shrink-0 text-sm font-medium px-4 py-1.5 rounded-full bg-white border border-gray-200 text-gray-600 hover:border-gray-400 hover:text-gray-900 transition-all whitespace-nowrap"
          >
            {p.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Product sections with sidebar -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16">
      <div class="lg:grid lg:grid-cols-[200px_1fr] lg:gap-10 items-start pt-12">

        <!-- Sidebar TOC -->
        <aside class="hidden lg:block">
          <div class="sticky top-8">
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">In this kit</p>
            <nav>
              {products.map((p) => (
                <a
                  href={`#${slugify(p.name)}`}
                  class="toc-link block py-2 text-sm text-slate-400 border-l-2 border-transparent pl-3 transition-all hover:text-gray-900"
                  data-section={slugify(p.name)}
                >
                  {p.name}
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <!-- Main content -->
        <div class="space-y-16">

          {products.map((product, i) => (
            <div id={slugify(product.name)} data-product-section>
              <div class="flex items-baseline gap-3 mb-4">
                <span class="bg-gray-900 text-white text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0">
                  {i + 1}
                </span>
                <h2 class="text-2xl sm:text-3xl font-extrabold text-gray-900">{product.name}</h2>
              </div>

              <p class="text-gray-600 leading-relaxed mb-5 max-w-3xl">{product.why}</p>

              <!-- Top pick callout -->
              <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 mb-2">
                <p class="text-xs font-semibold uppercase tracking-wide text-blue-600 mb-1">Our top pick</p>
                <p class="font-semibold text-gray-900 text-sm flex items-center gap-1.5">
                  {product.options[1].name}
                  <span class="score-tooltip">
                    <span class="score-icon">ⓘ</span>
                    <span class="score-tip">{product.score}</span>
                  </span>
                </p>
                <p class="text-sm text-gray-600 mt-1">{product.topPickReason}</p>
              </div>
              <p class="text-xs text-gray-400 mb-6">Score based on Amazon verified purchase reviews (50pts), independent lab tests (35pts), and beginner-friendliness (15pts).</p>

              <!-- Comparison table — desktop -->
              <div class="hidden sm:block overflow-hidden rounded-xl border border-gray-200">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="bg-[#0f172a]">
                      <th class="text-left px-5 py-3 font-semibold text-white w-24">Tier</th>
                      <th class="text-left px-5 py-3 font-semibold text-white">Product</th>
                      <th class="text-left px-5 py-3 font-semibold text-white w-32">Price</th>
                      <th class="text-left px-5 py-3 font-semibold text-white w-24">Link</th>
                    </tr>
                  </thead>
                  <tbody>
                    {product.options.map((opt, j) => (
                      <tr class={`${j < product.options.length - 1 ? 'border-b border-gray-100' : ''} ${j === 1 ? 'bg-blue-50/40' : 'bg-white'}`}>
                        <td class="px-5 py-3">
                          <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${tierColors[opt.tier]}`}>
                            {opt.tier}
                          </span>
                        </td>
                        <td class="px-5 py-3 font-medium text-gray-900">
                          {opt.name}
                          {j === 1 && <div class="mt-1.5"><span class="text-xs font-semibold text-green-700 bg-green-100 px-2 py-0.5 rounded-full">Best for beginners</span></div>}
                        </td>
                        <td class="px-5 py-3 text-gray-500">{opt.price}</td>
                        <td class="px-5 py-3">
                          <a href={opt.link} class="text-blue-600 hover:text-blue-800 font-semibold transition-colors">
                            {opt.retailer}
                          </a>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              <!-- Comparison cards — mobile -->
              <div class="sm:hidden space-y-3">
                {product.options.map((opt, j) => (
                  <div class={`rounded-xl border p-4 ${j === 1 ? 'border-blue-200 bg-blue-50/40' : 'border-gray-100 bg-white'}`}>
                    <div class="flex items-center justify-between mb-2">
                      <span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full ${tierColors[opt.tier]}`}>
                        {opt.tier}
                      </span>
                      <span class="text-sm text-gray-500 font-medium">{opt.price}</span>
                    </div>
                    <div class="mb-1">
                      <p class="font-semibold text-gray-900 text-sm">{opt.name}</p>
                      {j === 1 && <span class="mt-1 inline-block text-xs font-semibold text-green-700 bg-green-100 px-2 py-0.5 rounded-full">Best for beginners</span>}
                    </div>
                    <p class="text-xs text-gray-500 mb-3">{opt.bestFor}</p>
                    <a href={opt.link} class="inline-block text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors">
                      {opt.retailer}
                    </a>
                  </div>
                ))}
              </div>
            </div>
          ))}

        </div>
      </div>
    </section>

    <!-- Gift callout -->
    <section class="bg-amber-50 border-t border-amber-100">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="w-1 self-stretch bg-amber-300 rounded-full flex-shrink-0 hidden sm:block"></div>
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-1">Gift this kit</h2>
          <p class="text-gray-600 text-sm sm:text-base max-w-2xl">
            Know someone who just signed up for a 5K or started the Couch to 5K program? Running socks and a FlipBelt make a surprisingly thoughtful gift. It shows you know what they actually need on a run. Pair with the Brooks Ghost shoes if you know their size and you've covered everything.
          </p>
          <a href="/gifts" class="inline-block mt-3 text-sm font-semibold text-amber-700 hover:text-amber-900 transition-colors">
            See the full gift guide →
          </a>
        </div>
      </div>
    </section>

  </main>

</Layout>

<style>
  .score-tooltip {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .score-icon {
    color: #9ca3af;
    font-size: 14px;
    cursor: help;
    line-height: 1;
    font-style: normal;
  }
  .score-tip {
    visibility: hidden;
    opacity: 0;
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #1f2937;
    color: #fff;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    padding: 6px 10px;
    border-radius: 6px;
    max-width: 220px;
    width: max-content;
    white-space: normal;
    z-index: 20;
    transition: opacity 0.15s ease;
    pointer-events: none;
  }
  .score-tooltip:hover .score-tip {
    visibility: visible;
    opacity: 1;
  }
</style>
